# App
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/sylcchi_db?schema=public
DIRECT_URL=postgresql://username:password@localhost:5432/sylcchi_db?schema=public

# JWT
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# Better Auth
BETTER_AUTH_URL=http://localhost:5000
BETTER_AUTH_SECRET=change-me-better-auth-secret
FRONTEND_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP (optional in development)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@sylcchi.local

# Cloudinary (required for image upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe Payment Gateway
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_CURRENCY=usd
# Webhook signing secret: https://dashboard.stripe.com/webhooks
# For development: use any placeholder until webhook is deployed
STRIPE_WEBHOOK_SECRET=whsec_placeholder_for_dev

# SSLCommerz Payment Gateway (Bangladesh)
# Get credentials from: https://www.sslcommerz.com/
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_API_URL=https://sandbox.sslcommerz.com

# Booking Policy Rules
# Maximum stay allowed per booking (nights)
BOOKING_MAX_STAY_NIGHTS=11